# ─── LLM Provider ─────────────────────────────────────────────────────
# Supported: claude, gemini, openai
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_API_KEY=your-api-key-here

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/smde

# ─── Redis (Queue) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Server ──────────────────────────────────────────────────────────
PORT=8000
