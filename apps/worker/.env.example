# ─── LLM Provider ─────────────────────────────────────────────────────
# Supported: claude, gemini, openai
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_API_KEY=your-api-key-here

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/smde

# ─── Redis (Queue) ────────────────────────────────────────────────────
# Use REDIS_URL for a full connection string (supports rediss:// for TLS)
REDIS_URL=redis://localhost:6379
# Or use individual vars:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── Server ──────────────────────────────────────────────────────────
PORT=8000
